---
import BlobCursor from "@/components/externalComponents/BlobCursor";
import Loader from "@/components/Loader";
import Redes from "@/components/Redes/Redes";
import Header from '@/components/Header/Header';
---

<!doctype html>
<html lang="en" class="min-h-full min-w-full m-0 p-0 h-full w-full">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="José Barragán — Fullstack Developer especializado en NestJS, React y TypeScript. Mirá mis proyectos y contactame." />
		<meta name="generator" content={Astro.generator} />

		<title>José Barragán | Fullstack Developer</title>

		  <!-- Favicon -->
		<link rel="icon" type="image/png" href="../../public/jb_avatar_icon_v4_simple.svg"/>
		  <!-- Open Graph / Social preview -->
		<meta property="og:title" content="José Barragán | Fullstack Developer" />
		<meta property="og:description" content="Fullstack Developer especializado en NestJS, React y TypeScript." />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/og-image.png" />	
	</head>
	<body class="min-h-full min-w-full">
		<div class="hidden lg:block">
			<BlobCursor
			  blobType="circle"
			  fillColor="#e0bef8"
			  trailCount={1}
			  sizes={[45]}
			  innerSizes={[0,0,0]}
			  innerColor="rgba(224, 190, 248, 0.3)"
			  opacities={[1]}
			  shadowColor="rgba(224, 190, 248, 0.9)"
			  shadowBlur={40}
			  shadowOffsetX={0}
			  shadowOffsetY={0}
			  filterStdDeviation={0}
			  useFilter={false}
			  fastDuration={0.4}
			  slowDuration={0.1}
			  zIndex={900}
			  client:media="(min-width: 1024px)"
			/>
		</div>
		<Loader client:load /> 
		<Header client:visible/>
		<Redes client:visible />
		<slot />
	</body>
</html>
