---
import LightRays from "./externalComponents/LightRays"
import BlobCursor from "./externalComponents/BlobCursor"
import HeroText from "./HeroText"
---


<div id="container" class="w-full h-full">
	<div id="blob-wrapper">
		<BlobCursor
		  blobType="circle"
		  fillColor="#e0bef8"
		  trailCount={1}
		  sizes={[45]}
		  innerSizes={[0,0,0]}
		  innerColor="rgba(224, 190, 248, 0.3)"
		  opacities={[1]}
		  shadowColor="rgba(224, 190, 248, 0.9)"
		  shadowBlur={40}
		  shadowOffsetX={0}
	      shadowOffsetY={0}
		  filterStdDeviation={0}
		  useFilter={false}
		  fastDuration={0.1}
		  slowDuration={0.2}
		  zIndex={100}
		  client:load
		/>
	</div>
	<LightRays
		raysOrigin="top-center"
		raysColor="#63328e"
		raysSpeed={1}
		lightSpread={3}
		rayLength={60}
		pulsating={false}
		fadeDistance={1}
		saturation={2}
		followMouse={false}
		mouseInfluence={0.1}
		noiseAmount={0}
		distortion={0}
	  client:load
	  />
	<main class="w-full h-full relative">
		<HeroText client:load/>
	</main>
</div>

<script>
  const wrapper = document.getElementById('blob-wrapper')
  if ('ontouchstart' in window || navigator.maxTouchPoints > 0) {
    wrapper?.remove()
  }
</script>

