---
import TechGrid from "@/components/TechStack/TechGrid.astro"
import Orb from "@/components/externalComponents/Orb"

const username = "JoseeBarragan";

async function getContributions(user: string) {
  const query = `
    query($username: String!) {
      user(login: $username) {
        contributionsCollection {
          contributionCalendar {
            weeks {
              contributionDays {
                contributionCount
                date
              }
            }
          }
        }
      }
    }
  `;

  try {
    const response = await fetch('https://api.github.com/graphql', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${import.meta.env.GITHUB_TOKEN}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ query, variables: { username: user } }),
    });
    const json = await response.json();
    return json?.data?.user?.contributionsCollection?.contributionCalendar?.weeks || [];
  } catch (error) {
    console.error("Error fetching GitHub data:", error);
    return [];
  }
}

const weeks = await getContributions(username);

const monthLabels = weeks.reduce((acc: { name: string, index: number }[], week: any, index: number) => {
  const firstDay = new Date(week.contributionDays[0].date);
  const monthName = firstDay.toLocaleString('default', { month: 'short' });
  
  // Si es el primer mes o es un mes nuevo, lo añadimos a la lista
  if (acc.length === 0 || acc[acc.length - 1].name !== monthName) {
    acc.push({ name: monthName, index: index });
  }
  return acc;
}, []);

---

<section id="stack" class="w-full md:pl-20 lg:pl-16 xl:pl-0 relative min-h-screen flex flex-col items-center justify-center gap-16 py-20"
  style="background: linear-gradient(to bottom, #0f0111 0%, #0f0111 35%);"
>
  <div class="w-full h-full absolute inset-0 z-0 pointer-events-none">
    <Orb
      hue={312}
      hoverIntensity={0}
      rotateOnHover={false}
      forceHoverState={false}
      client:idle
    />
  </div>

  <div class="relative w-full max-w-5xl px-4">
    <TechGrid />
  </div>

  <div class="relative z-900 w-full max-w-4xl px-4">
    
    <div class="flex items-center gap-2.5 mb-4 text-white/80">
      <div 
        id="contributions-label-wrapper"
        class="relative flex items-center gap-2.5 mb-4 text-white/80"
      >
        <!-- Base layer -->
        <svg class="w-5 h-5 fill-current opacity-70" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M8 0c4.42 0 8 3.58 8 8 0 3.54-2.29 6.53-5.47 7.59-.4.07-.55-.17-.55-.38 0-.19.01-.82.01-1.49 2.01.37 2.53-.49 2.69-.94.09-.23.48-.94.82-1.13.28-.15.68-.52.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
        </svg>
        <h3 class="text-sm font-semibold tracking-wider select-none opacity-80">CONTIBUTIONS</h3>

        <!-- Mask layer -->
        <div
          id="contributions-mask-layer"
          class="absolute inset-0 flex delayed-position items-center gap-2.5 pointer-events-none"
          style="-webkit-mask-image: radial-gradient(circle 25px at var(--x, -999px) var(--y, -999px), black 90%, transparent 10%); mask-image: radial-gradient(circle 25px at var(--x, -999px) var(--y, -999px), black 90%, transparent 10%);"
        >
          <svg class="w-5 h-5 fill-black opacity-100" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M8 0c4.42 0 8 3.58 8 8 0 3.54-2.29 6.53-5.47 7.59-.4.07-.55-.17-.55-.38 0-.19.01-.82.01-1.49 2.01.37 2.53-.49 2.69-.94.09-.23.48-.94.82-1.13.28-.15.68-.52.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
          </svg>
          <h3 class="text-sm font-semibold tracking-wider text-black select-none">CONTIBUTIONS</h3>
        </div>
      </div>   
    </div>

    <div class="p-6 bg-[#09040e]/60 backdrop-blur-xl border border-white/5 rounded-2xl shadow-[0_4px_30px_rgba(0,0,0,0.4)]">
      
      <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-none">
        
        <div class="flex flex-col justify-between text-[10px] text-white/40 font-medium pr-1 pt-5 pb-1 select-none">
          <span>Mon</span>
          <span>Wed</span>
          <span>Fri</span>
        </div>

        <div class="flex flex-col gap-1.5 flex-1">
          
          <div class="flex justify-between text-[10px] text-white/40 font-medium px-1 select-none">
            {monthLabels.map((label) => <span>{label.name}</span>)}
          </div>

          <div class="flex gap-0.75">
            {weeks.length > 0 ? (
              weeks.map((week: any) => (
                <div class="flex flex-col gap-0.75">
                  {week.contributionDays.map((day: any) => {
                    const count = day.contributionCount;
                    
                    // Paleta de colores Neon Violet / Purple
                    const color = count === 0 ? 'bg-white/[0.03] border border-white/[0.01]' : 
                      count < 3 ? 'bg-[#7e22ce] shadow-[0_0_6px_rgba(126,34,206,0.4)]' : // Violeta vivo intenso
                      count < 6 ? 'bg-[#a855f7] shadow-[0_0_10px_rgba(168,85,247,0.6)]' : // Púrpura brillante
                      count < 9 ? 'bg-[#c084fc] shadow-[0_0_14px_rgba(192,132,252,0.8)]' : // Púrpura claro eléctrico
                      'bg-[#f472b6] shadow-[0_0_18px_rgba(244,114,182,0.9)]'; // Rosa/Fucsia neón (Actividad máxima)                    
                    return (
                      <div 
                        class={`w-2.75 h-2.75 sm:w-2.75 sm:h-2.75 rounded-xs transition-all duration-300 hover:scale-125 hover:z-20 cursor-pointer ${color}`} 
                        title={`${count} contribuciones el ${day.date}`}
                      />
                    );
                  })}
                </div>
              ))
            ) : (
              <p class="text-white/40 text-xs py-6 w-full text-center">No token found or user has no data.</p>
            )}
          </div>
        </div>
      </div>

      <div class="flex justify-end items-center gap-1.5 text-[10px] text-white/40 mt-4 select-none pr-1">
        <span>Less</span>
        <div class="w-2.25 h-2.25 rounded-[1px] bg-white/4"></div>
        <div class="w-2.25 h-2.25 rounded-[1px] bg-purple-950/60"></div>
        <div class="w-2.25 h-2.25 rounded-[1px] bg-purple-800"></div>
        <div class="w-2.25 h-2.25 rounded-[1px] bg-purple-600"></div>
        <div class="w-2.25 h-2.25 rounded-[1px] bg-fuchsia-500"></div>
        <span>More</span>
      </div>

    </div>
    <p class="relative text-xs text-white text-center pt-2 font-mono ">
      © 2025 José Barragán
    </p> 
  </div>
 
</section>

<style>
  /* Evitamos que la barra de scroll rompa la UI en móviles */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
