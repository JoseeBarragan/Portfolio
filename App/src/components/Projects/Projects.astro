---
import BorderGlow from "../externalComponents/BorderGlow";
import DotField from "../externalComponents/DotField";
---
<section class="w-full h-full min-h-full z-900">
  <div class="sticky top-0 h-screen overflow-hidden bg-linear-to-b from-transparent from-0% via-purple-950/70 via-20% to-[#0d0010] to-100%" style="z-index: 800; margin-bottom: -100vh;">
    <div style="width: 100vw; height: 100vh; position: relative;">
      <div class="absolute top-0 left-0 w-full h-full pointer-events-auto" style="z-index: 800;">
        <DotField 
          dotRadius={2}
          dotSpacing={15}
          cursorRadius={400}
          cursorForce={0.02}
          bulgeOnly
          bulgeStrength={41}
          glowRadius={50}
          sparkle
          waveAmplitude={0}
          gradientFrom="rgba(168, 85, 247, 0.35)"
          gradientTo="rgba(180, 151, 207, 0.25)"
          glowColor="#120F17"
          client:visible 
        />
      </div>
    </div>
  </div>
  <div class="relative flex pointer-events-none items-center z-900 justify-center h-full gap-8">
    <div class="relative pointer-events-auto" style="z-index: 1000;">
        <BorderGlow
          edgeSensitivity={1}
          glowColor="40 80 80"
          backgroundColor="#120F17"
          borderRadius={16}
          glowRadius={40}
          glowIntensity={1.5}
          coneSpread={25}
          animated
          className="z-1000"
          colors={['#c084fc', '#f472b6', '#38bdf8']}
          client:visible
        >
          <div class="flex flex-col h-full min-h-80 w-full max-w-87.5 p-6 text-zinc-100 justify-between">
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class="text-[10px] font-mono tracking-widest text-purple-400 uppercase">Project 01</span>
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_8px_#34d399]"></div>
              </div>
              <h3 class="text-xl font-bold text-white mb-2">Nombre del Proyecto</h3>
              <p class="text-sm text-zinc-400 leading-relaxed">
                Descripción breve y concisa de tu proyecto. Explica el problema que resuelve y tu rol en el desarrollo.
              </p>
            </div>
            <div>
              <div class="flex flex-wrap gap-2 mb-6">
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">React</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">Astro</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">Tailwind</span>
              </div>
              <div class="flex items-center justify-between pt-4 border-t border-zinc-800/50">
                <a href="#" class="text-xs text-zinc-400 hover:text-white transition-colors">Github</a>
                <a href="#" class="px-3 py-1.5 text-xs font-bold rounded-lg bg-zinc-800 hover:bg-zinc-700 text-white border border-zinc-700/50 transition-all">Live Demo</a>
              </div>
            </div>
          </div>
        </BorderGlow>
      </div>
      <div class="relative pointer-events-auto" style="z-index: 1000;">
        <BorderGlow
          edgeSensitivity={1}
          glowColor="40 80 80"
          backgroundColor="#120F17"
          borderRadius={16}
          glowRadius={40}
          glowIntensity={1.5}
          coneSpread={25}
          animated
          className="z-1000"
          colors={['#c084fc', '#f472b6', '#38bdf8']}
          client:visible
        >
          <div class="flex flex-col h-full min-h-80 w-full max-w-87.5 p-6 text-zinc-100 justify-between">
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class="text-[10px] font-mono tracking-widest text-cyan-400 uppercase">Project 02</span>
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_8px_#34d399]"></div>
              </div>
              <h3 class="text-xl font-bold text-white mb-2">Segundo Proyecto</h3>
              <p class="text-sm text-zinc-400 leading-relaxed">
                Otra descripción impactante. Mantén el estilo visual coherente para resaltar la calidad de tu trabajo.
              </p>
            </div>
            <div>
              <div class="flex flex-wrap gap-2 mb-6">
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">TypeScript</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">Node.js</span>
              </div>
              <div class="flex items-center justify-between pt-4 border-t border-zinc-800/50">
                <a href="#" class="text-xs text-zinc-400 hover:text-white transition-colors">Github</a>
                <a href="#" class="px-3 py-1.5 text-xs font-bold rounded-lg bg-zinc-800 hover:bg-zinc-700 text-white border border-zinc-700/50 transition-all">Live Demo</a>
              </div>
            </div>
          </div>
        </BorderGlow>
      </div>
    </div>
</section>