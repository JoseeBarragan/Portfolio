---
import BorderGlow from "../externalComponents/BorderGlow";
import DotField from "../externalComponents/DotField";
import GymImage from "../../assets/try1.png"
---
<section class="w-full h-full min-h-full z-900">
  <div class="sticky top-0 h-screen overflow-hidden bg-linear-to-b from-transparent from-0% via-purple-950/70 via-20% to-[#0d0010] to-100%" style="z-index: 800; margin-bottom: -100vh;">
    <div style="width: 100vw; height: 100vh; position: relative;">
      <div class="absolute top-0 left-0 w-full h-full pointer-events-auto" style="z-index: 800;">
        <DotField 
          dotRadius={2}
          dotSpacing={15}
          cursorRadius={400}
          cursorForce={0.02}
          bulgeOnly
          bulgeStrength={41}
          glowRadius={50}
          sparkle
          waveAmplitude={0}
          gradientFrom="rgba(168, 85, 247, 0.35)"
          gradientTo="rgba(180, 151, 207, 0.25)"
          glowColor="#120F17"
          client:visible 
        />
      </div>
    </div>
  </div>
  <div class="relative flex pointer-events-none items-center z-900 justify-evenly h-full gap-8">
    <div class="relative pointer-events-auto" style="z-index: 1000;">
        <BorderGlow
          edgeSensitivity={1}
          glowColor="40 80 80"
          backgroundColor="#120F17"
          borderRadius={16}
          glowRadius={40}
          glowIntensity={1.5}
          coneSpread={25}
          animated
          className="z-1000"
          colors={['#c084fc', '#f472b6', '#38bdf8']}
          client:visible
        >
          <div class="flex flex-col h-full min-h-80 max-h-130 w-full max-w-150 p-6 text-zinc-100 justify-between">
            <img
              src=""
              alt="Preview del proyecto"
              class="w-full h-52 object-cover object-[center_20%] rounded-t-2xl"
              loading="lazy"
              decoding="async"
            />
            <div>
              <div class="flex items-center justify-between my-4">
                <h3 class="text-xl font-bold text-white mb-2">Restaurant Management System</h3>
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_8px_#34d399]"></div>
              </div>
              <p class="text-sm text-zinc-400 leading-relaxed">
                Fullstack app that lets customers scan a QR code at their table to browse the menu, place orders and pay. Includes a dashboard for waiters, kitchen staff and admins to manage tables, products and payments via Mercado Pago.
              </p>
            </div>
            <div>
              <div class="flex flex-wrap gap-2 my-6">
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">React</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">TypeScript</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">Node.js</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">PostgreSQL</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">Mercado Pago</span>
              </div>
              <div class="flex items-center justify-between pt-4 border-t border-zinc-800/50">
                <a href="#" class="text-xs text-zinc-400 hover:text-white transition-colors">GitHub</a>
              </div>
            </div>
          </div>
        </BorderGlow>
      </div>
      <div class="relative pointer-events-auto" style="z-index: 1000;">
        <BorderGlow
          edgeSensitivity={1}
          glowColor="40 80 80"
          backgroundColor="#120F17"
          borderRadius={16}
          glowRadius={40}
          glowIntensity={1.5}
          coneSpread={25}
          animated
          className="z-1000"
          colors={['#c084fc', '#f472b6', '#38bdf8']}
          client:visible
        >
          <div class="flex flex-col h-full min-h-80 max-h-130 w-full max-w-150 p-6 text-zinc-100 justify-between">
            <img
              src={GymImage.src}
              alt="Preview Gym Management System"
              class="w-full h-52 object-cover rounded-t-2xl"
              loading="lazy"
              decoding="async"
            />
            <div>
              <div class="flex items-center justify-between my-4">
                <h3 class="text-xl font-bold text-white mb-2">Gym Management System</h3>
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_8px_#34d399]"></div>
              </div>
              <p class="text-sm text-zinc-400 leading-relaxed">
                Fullstack gym management app with role-based access control for admins, instructors and members. Handles class scheduling, reservations, membership tracking and payments via Stripe.
              </p>
            </div>
            <div>
              <div class="flex flex-wrap gap-2 my-6">
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">NestJS</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">React</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">TypeScript</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">PostgreSQL</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">Docker</span>
                <span class="px-2 py-1 text-[10px] rounded-md bg-zinc-800/50 text-zinc-300 border border-zinc-700/30">Stripe</span>
              </div>
              <div class="flex items-center justify-between pt-4 border-t border-zinc-800/50">
                <a href="#" class="text-xs text-zinc-400 hover:text-white transition-colors">GitHub</a>
              </div>
            </div>
          </div>
        </BorderGlow>
      </div>
    </div>
</section>