---
<div id="hero-text-wrapper" class="z-900">
  <div
    id="hero-text-container"
    class="relative flex items-center justify-center w-full md:w-auto px-6 md:px-0 select-none"
  >
    <div id="base-layer" class="text-center lg:text-start">
      <p class="font-sans text-[clamp(0.7rem,3vw,1.5rem)] text-[#bda0f8] tracking-[0.25em] mb-3 font-light">
        Hello, I'm
      </p>
      <h1 class="font-mono text-[clamp(1.7rem,4vw,7rem)] text-[#cccccc] leading-[1.1] tracking-[0.02em]">
        JOSÉ BARRAGÁN
      </h1>
      <h2 class="font-mono text-[clamp(0.9rem,3vw,2rem)] text-[#bda0f8] font-normal mt-[0.4rem] leading-[1.1] tracking-[0.02em]">
        FULLSTACK DEVELOPER
      </h2>
    </div>
  
    <div
      id="blob-layer"
      class="absolute inset-0 flex items-center justify-center z-900 delayed-position"
      style="-webkit-mask-image: radial-gradient(circle 25px at var(--x, -999px) var(--y, -999px), black 90%, transparent 10%); mask-image: radial-gradient(circle 25px at var(--x, -999px) var(--y, -999px), black 90%, transparent 10%);"
    >
      <div class="text-center lg:text-start "> 
        <p class="font-sans text-[clamp(0.7rem,3vw,1.5rem)] text-black tracking-[0.25em] mb-3 font-light">
          Hello, I'm
        </p>
        <h1 class="font-mono text-[clamp(1.7rem,4vw,7rem)] text-black leading-[1.1] tracking-[0.02em]">
          JOSÉ BARRAGÁN
        </h1>
        <h2 class="font-mono text-[clamp(0.9rem,3vw,2rem)] text-black font-normal mt-[0.4rem] leading-[1.1] tracking-[0.02em]">
          FULLSTACK DEVELOPER
        </h2>
      </div>
    </div>
  </div>
</div>
