---
import LightRays from "../externalComponents/LightRays"
import HeroText from "../Hero/HeroText.astro"
import VSTerminal from "./HeroTerminal"
import Terminal from "./Terminal.astro"
import TerminalBack from "./TerminalBack"
import ScrollFloat from '../externalComponents/ScrollFloat';
---

<section id="hero-section" class="relative w-full" style="height: 200vh;">

  <!-- LightRays: NO sticky, fondo estático arriba -->
  <div class="sticky top-0 h-screen overflow-hidden pointer-events-none" style="z-index: 0; margin-bottom: -100vh;">
    <LightRays
      raysOrigin="top-center"
      raysColor="#63328e"
      raysSpeed={1}
      lightSpread={3}
      rayLength={60}
      pulsating={false}
      fadeDistance={1}
      saturation={2}
      followMouse={false}
      mouseInfluence={0.1}
      noiseAmount={0}
      distortion={0}
      client:load
    />
  </div>

  <!-- Contenido sticky -->
  <div
    class="top-0 h-screen w-full flex flex-col items-center justify-center"
    style="z-index: 10;"
  >
    <!-- Texto: NO sticky, sale con scroll -->
    <div
      id="hero-text"
      class="lg:absolute text-center"
      style="left: clamp(2rem, 8vw, 12rem);"
    >
      <HeroText />
    </div>

    <!-- Terminal wrapper: sticky, centrada horizontalmente al final -->
    <div
      id="hero-terminal-wrapper"
      class="hidden lg:block shrink-0 absolute lg:right-10 xl:right-30 perspective-[1500px] perspective-origin-[center_center]"
    >
      <div id="hero-card" style="transform-style: preserve-3d; position: relative;">
        <VSTerminal client:load><Terminal /></VSTerminal>
        <TerminalBack client:load/>
      </div>
    </div>

   <div 
      id="right-about-text" 
      class="z-900 pointer-events-auto absolute lg:right-[1%] xl:right-[5%] lg:top-[75%] md:top-[65%] lg:-translate-y-1/2 flex items-center justify-center lg:block w-full lg:w-auto px-6 lg:px-0"
    >
      <div class="relative ">
        
        <div class="flex flex-col items-center text-center lg:items-start lg:text-left transition-opacity duration-500">
          <h2 class="font-mono tracking-widest text-[#bda0f8] text-4xl md:text-5xl lg:text-6xl leading-tight mb-4 select-none">
            ABOUT ME<br/>
          </h2>
          <div class="flex font-extrabold flex-col gap-3 text-[#e5dfe6] text-sm md:text-base lg:text-lg xl:text-2xl font-sans max-w-md xl:max-w-xl mx-auto lg:mx-0 leading-relaxed select-none">
            <p>
              I am a Fullstack Developer and a System Engineering student at UTN, currently halfway through my degree.
            </p>
            <p>
              Beyond specific frameworks like TypeScript, React, and NestJS, I am deeply driven by robust system design, scalable infrastructure, and performance optimization. 
            </p>
            <p>
              I don't just build features; I architect solutions. I am constantly learning, bridging the gap between academic theory and real-world engineering to deliver cleaner, more efficient systems.
            </p>
          </div>
        </div>

        <div 
          id="about-mask-layer"
          class="absolute inset-0 flex flex-col z-900 items-center text-center lg:items-start lg:text-left duration-300"
          style="-webkit-mask-image: radial-gradient(circle 47px at var(--x, -999px) var(--y, -999px), black 0%, transparent 100%); mask-image: radial-gradient(circle 47px at var(--x, -999px) var(--y, -999px), black 0%, transparent 100%);"
          aria-hidden="true"
        >
          <h2 class="font-mono tracking-widest text-[#251f01] text-4xl md:text-5xl lg:text-6xl leading-tight mb-4 select-none drop-shadow-[0_0_12px_rgba(189,160,248,0.6)]">
            ABOUT ME<br/>
          </h2>
          <div class="flex font-extrabold flex-col gap-3 text-[#251f01] text-sm md:text-base lg:text-lg xl:text-2xl font-sans max-w-md xl:max-w-xl mx-auto lg:mx-0 leading-relaxed select-none">
            <p>
              I am a Fullstack Developer and a System Engineering student at UTN, currently halfway through my degree.
            </p>
            <p>
              Beyond specific frameworks like TypeScript, React, and NestJS, I am deeply driven by robust system design, scalable infrastructure, and performance optimization. 
            </p>
            <p>
              I don't just build features; I architect solutions. I am constantly learning, bridging the gap between academic theory and real-world engineering to deliver cleaner, more efficient systems.
            </p>
          </div>
        </div>

      </div>
    </div>

</section>

<script>
  import gsap from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'
 
  gsap.registerPlugin(ScrollTrigger)
 
  document.addEventListener('DOMContentLoaded', () => {
    const heroCard    = document.getElementById('hero-card')
    const heroWrapper = document.getElementById('hero-terminal-wrapper')
    const aboutWrapper = document.getElementById('right-about-text')
    const maskLayer    = document.getElementById('about-mask-layer')
    const container = document.getElementById('hero-text-wrapper');
    const blobLayer = document.getElementById('blob-layer');

    if (container && blobLayer) {
      window.addEventListener('blob-move', ((e: CustomEvent) => {
        const rect = container.getBoundingClientRect();
        const x = e.detail.x - rect.left
        const y = e.detail.y - rect.top

        blobLayer.style.setProperty('--x', `${x}px`);
        blobLayer.style.setProperty('--y', `${y}px`);
      }) as EventListener);
    }

    if (aboutWrapper && maskLayer) {

      window.addEventListener('mousemove', (e) => {
          window.requestAnimationFrame(() => {
            const rect = aboutWrapper.getBoundingClientRect()
            const x = e.clientX - rect.left
            const y = e.clientY - rect.top
            
            maskLayer.style.setProperty('--x', `${x}px`)
            maskLayer.style.setProperty('--y', `${y}px`)
            
        })
      })
    }
 
    if (!container || !heroCard || !heroWrapper) return
 
    ScrollTrigger.refresh()
 
    const mm = gsap.matchMedia()
 
    mm.add('(min-width: 1024px)', () => {
      const wrapperRect = heroWrapper.getBoundingClientRect()
      const leftX = -(wrapperRect.left - 125)
 
      const viewportHeight = window.innerHeight
      const downY = viewportHeight * 1.0 

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '#hero-section',
          start: 'top top',
          end: 'bottom bottom',
          scrub: 1,
          invalidateOnRefresh: true,
          onUpdate: (self) => {
            if (self.progress === 1) {
              window.dispatchEvent(new CustomEvent('start-terminal-typing'))
            }
          }
        },
      })

      tl.to(heroWrapper,
        { 
          x: leftX, 
          y: downY, 
          ease: 'power1.inOut', 
          duration: 0.8
        },
        0.2
      )
      
      tl.to(heroCard,
        { rotateY: 180, ease: 'none', duration: 0.8 },
        0.2
      )
 
      tl.to(heroCard,
        { height: '70vh', ease: 'power1.inOut', duration: 0.4 },
        0.6
      )
 
      return () => {}
    })
  })
</script>