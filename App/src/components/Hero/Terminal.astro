---
---
<div class="terminal">
  <div class="tab-bar">
    <div class="dots">
      <span class="dot red" />
      <span class="dot yellow" />
      <span class="dot green" />
    </div>
    <div class="tab">
      <span class="tab-dot">●</span>
      developer.ts
    </div>
  </div>

  <div class="code-area">
    <div class="line-numbers">
      {Array.from({ length: 10 }).map((_, i) => (
        <div>{i + 1}</div>
      ))}
    </div>
    <div class="code-lines">
      <div class="line"><span class="cm">// Welcome to my workspace</span></div>
      <div class="line"><span class="kw">import</span> <span class="br">{`{`}</span> <span class="ty">Developer</span> <span class="br">{`}`}</span> <span class="kw">from</span> <span class="str">'./universe'</span>;</div>
      <div class="line">&nbsp;</div>
      <div class="line"><span class="kw">const</span> <span class="fn">Portfolio</span> <span class="op">=</span> <span class="pr">()</span> <span class="op">=&gt;</span> <span class="br">{`{`}</span></div>
      <div class="line indent"><span class="kw">return</span> <span class="pr">(</span></div>
      <div class="line indent">&nbsp;&nbsp;<span class="op">&lt;</span><span class="ty">Developer</span></div>
      <div class="line indent">&nbsp;&nbsp;&nbsp;&nbsp;<span class="ke">name</span><span class="op">=</span><span class="str">"José Barragán"</span></div>
      <div class="line indent">&nbsp;&nbsp;&nbsp;&nbsp;<span class="ke">role</span><span class="op">=</span><span class="str">"Fullstack Developer"</span></div>
      <div class="line indent">&nbsp;&nbsp;&nbsp;&nbsp;<span class="ke">stack</span><span class="op">=</span><span class="str">"NestJS · React · TypeScript"</span></div>
      <div class="line indent">&nbsp;&nbsp;&nbsp;&nbsp;<span class="ke">db</span><span class="op">=</span><span class="str">"PostgreSQL · Prisma"</span></div>
      <div class="line indent">&nbsp;&nbsp;<span class="op">/&gt;</span></div>
      <div class="line indent"><span class="pr">)</span>;</div>
      <div class="line"><span class="br">{`}`}</span>;</div>
    </div>
  </div>
</div>

<style>
  .terminal {
    width: clamp(340px, 40vw, 520px);
    background: #1e1e2e;
    border-radius: 12px;
    overflow: hidden;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 13px;
    border: 1px solid #313244;
  }
  .tab-bar {
    background: #181825;
    border-bottom: 1px solid #313244;
    padding: 0 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    height: 38px;
  }
  .fn { color: #f7c201; }
  .dots { display: flex; gap: 6px; }
  .dot { width: 12px; height: 12px; border-radius: 50%; display: block; }
  .red    { background: #ff5f57; }
  .yellow { background: #febc2e; }
  .green  { background: #28c840; }
  .tab {
    margin-left: 0.5rem;
    background: #1e1e2e;
    border: 1px solid #313244;
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    padding: 4px 14px;
    color: #cdd6f4;
    font-size: 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .tab-dot { color: #89b4fa; font-size: 10px; }
  .code-area { display: flex; padding: 1rem 0; }
  .line-numbers {
    min-width: 36px;
    text-align: right;
    padding: 0 0.75rem;
    color: #45475a;
    user-select: none;
    line-height: 1.85;
    font-size: 12px;
  }
  .code-lines { line-height: 1.85; padding-right: 1.2rem; flex: 1; }
  .line { display: block; white-space: nowrap; }
  .indent { padding-left: 1.5rem; }
  .buttons-area {
    padding: 0.75rem 1rem 1rem;
    display: flex;
    gap: 0.75rem;
  }
  .btn {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 8px 18px;
    border-radius: 6px;
    font-family: inherit;
    font-size: 12.5px;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid;
  }
  .btn-primary  { background: transparent; border-color: #f38ba8; color: #f38ba8; }
  .btn-secondary { background: transparent; border-color: #45475a; color: #cdd6f4; }

  /* Syntax highlighting */
  :global(.cm)  { color: #6c7086; font-style: italic; }
  :global(.kw)  { color: #cba6f7; }
  :global(.va)  { color: #89dceb; }
  :global(.ke)  { color: #89b4fa; }
  :global(.ty)  { color: #f9e2af; }
  :global(.str) { color: #a6e3a1; }
  :global(.op)  { color: #cdd6f4; }
  :global(.br)  { color: #cba6f7; }
  :global(.pr)  { color: #fab387; }
</style>